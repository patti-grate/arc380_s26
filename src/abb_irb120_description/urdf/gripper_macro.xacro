<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro">

  <xacro:property name="color_abb_graphite_white" value="0.7725490 0.7803922 0.7686275 1" />

  <xacro:macro name="material_abb_graphite_white">
    <material name="">
      <color rgba="${color_abb_graphite_white}"/>
    </material>
  </xacro:macro>

  <xacro:macro name="gripper" params="prefix">
    <link name="${prefix}gripper_base">
      <inertial>
        <mass value="1.0"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
      </inertial>
      <collision name="collision">
        <geometry>
          <mesh filename="package://abb_irb120_description/meshes/collision/gripper_base.stl"/>
        </geometry>
      </collision>
      <visual name="visual">
        <geometry>
          <mesh filename="package://abb_irb120_description/meshes/visual/gripper_base.stl"/>
        </geometry>
        <xacro:material_abb_graphite_white />
      </visual>
    </link>
    <link name="${prefix}left_finger">
      <inertial>
        <mass value="0.5"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="1e-4"/>
      </inertial>
      <collision name="collision">
        <geometry>
          <mesh filename="package://abb_irb120_description/meshes/collision/left_finger.stl"/>
        </geometry>
      </collision>
      <visual name="visual">
        <geometry>
          <mesh filename="package://abb_irb120_description/meshes/visual/left_finger.stl"/>
        </geometry>
        <xacro:material_abb_graphite_white />
      </visual>
    </link>
    <link name="${prefix}right_finger">
      <inertial>
        <mass value="0.5"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="1e-4"/>
      </inertial>
      <collision name="collision">
        <geometry>
          <mesh filename="package://abb_irb120_description/meshes/collision/right_finger.stl"/>
        </geometry>
      </collision>
      <visual name="visual">
        <geometry>
          <mesh filename="package://abb_irb120_description/meshes/visual/right_finger.stl"/>
        </geometry>
        <xacro:material_abb_graphite_white />
      </visual>
    </link>

    <gazebo reference="${prefix}left_finger">
      <mu1>1000.0</mu1>
      <mu2>1000.0</mu2>
      <kp>1000000000.0</kp>
      <kd>1000000.0</kd>
      <maxVel>0.01</maxVel>
      <minDepth>0.001</minDepth>
    </gazebo>

    <gazebo reference="${prefix}right_finger">
      <mu1>1000.0</mu1>
      <mu2>1000.0</mu2>
      <kp>1000000000.0</kp>
      <kd>1000000.0</kd>
      <maxVel>0.01</maxVel>
      <minDepth>0.001</minDepth>
    </gazebo>

    <joint name="${prefix}left_finger_joint" type="prismatic">
        <parent link="${prefix}gripper_base"/>
        <child link="${prefix}left_finger"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <axis xyz="0 -1 0"/>
        <limit lower="-0.001" upper="0.025" effort="5000" velocity="0.05"/>
        <dynamics damping="1.0" friction="0.1"/>
    </joint>

    <joint name="${prefix}right_finger_joint" type="prismatic">
        <parent link="${prefix}gripper_base"/>
        <child link="${prefix}right_finger"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <mimic joint="${prefix}left_finger_joint" multiplier="1.0" offset="0.0"/>
        <limit lower="-0.001" upper="0.025" effort="5000" velocity="0.05"/>
        <dynamics damping="1.0" friction="0.1"/>
    </joint>

    <link name="${prefix}gripper_tcp"/>
    <joint name="${prefix}gripper_base-gripper_tcp" type="fixed">
        <parent link="${prefix}gripper_base"/>
        <child link="${prefix}gripper_tcp"/>
        <origin xyz="0 0 0.1353" rpy="0 0 0"/>
    </joint>

    <link name="${prefix}gripper_tcp_calibrated"/>
    <joint name="${prefix}gripper_base-gripper_tcp_calibrated" type="fixed">
        <parent link="${prefix}gripper_base"/>
        <child link="${prefix}gripper_tcp_calibrated"/>
        <origin xyz="0 0 0.139" rpy="0 0 ${radians(45)}"/>
    </joint>

  </xacro:macro>
</robot>
